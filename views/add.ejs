<!DOCTYPE html>
<html lang="sv">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/main.css">
    <script type="module" src="/js/main.js"></script>
    <title>DT207G - Laboration 1
    </title>
</head>

<body>
    <div class="container">
        <%- include("partials/header") %>
        <main>
            <h1>Lägg till kurs</h1>

            <% if(locals.errors.length > 0) { %>
                <ul>
                <% errors.forEach((error) => { %>
                    <li>
                        <%= error %>
                    </li>
                <% }); %>
                </ul>
            <% }; %>
            <div id="form-course">
                <form id="add-course" method="post">
                    <label for="code">Kurskod:</label><br>
                    <input type="text" id="code" name="coursecode" value="<%= courseCode %>">
                    <br>
                    <label for="name">Kursnamn:</label><br>
                    <input type="text" id="name" name="coursename" value="<%= courseName %>">
                    <br>
                    <label for="prog">Progression:</label><br>
                    <input type="text" id="prog" name="courseprogression" value="<%= progression %>">
                    <br>
                    <label for="syll">URL:</label><br>
                    <input type="text" id="syll" name="coursesyllabus" value="<%= syllabus %>">
                    <br>
                    <input type="submit" value="Spara kurs">
                </form>
            </div>
        </main>
        <footer>
            <p>Skapad av Hanna Lindkvist</p>
        </footer>
    </div> <!--Container slut-->
</body>

</html>